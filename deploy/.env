# PostgreSQL 主库
DB_URL=jdbc:postgresql://db:5432/deskpet?currentSchema=deskpet&stringtype=unspecified
DB_USER=deskpet
DB_PASSWORD=deskpet

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=deskpet080078

# TimescaleDB 时序库
TSDB_ENABLED=true
TSDB_URL=jdbc:postgresql://tsdb:5432/deskpet_ts
TSDB_USER=deskpet
TSDB_PASSWORD=deskpet
TSDB_LOG_LEVEL=INFO

# Snowflake 分布式 ID
SNOWFLAKE_WORKER_ID=0

# MQTT 网关
GATEWAY_INSTANCE_ID=gateway-1
INTERNAL_TOKEN=

# pet-ai 模块
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
PET_CORE_URL=http://pet-core:8080
