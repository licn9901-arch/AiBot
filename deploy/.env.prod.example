1# PostgreSQL 主库
DB_URL=jdbc:postgresql://db:5432/deskpet?currentSchema=deskpet&stringtype=unspecified
DB_USER=deskpet
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2

# TimescaleDB 时序库
TSDB_ENABLED=true
TSDB_URL=jdbc:postgresql://tsdb:5432/deskpet_ts
TSDB_USER=deskpet
TSDB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_3
TSDB_LOG_LEVEL=WARN

# Snowflake 分布式 ID（多实例部署时每个实例需不同）
SNOWFLAKE_WORKER_ID=0

# 内部服务通信 Token（pet-core 与 mqtt-gateway 之间）
INTERNAL_TOKEN=CHANGE_ME_RANDOM_TOKEN

# MQTT 对外端口
MQTT_PORT=1883

# 镜像仓库前缀（如 registry.cn-hangzhou.aliyuncs.com/yournamespace/）
REGISTRY=
# 镜像标签
TAG=latest

# pet-ai 模块
OPENAI_API_KEY=sk-your-real-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
